{
  "name": "truckfixr-fleet-ai",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build:client": "cross-env NODE_ENV=production vite build",
    "build:server": "cross-env NODE_ENV=production esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build": "pnpm build:client && pnpm build:server",
    "start:server": "cross-env NODE_ENV=production node dist/index.js",
    "start": "pnpm start:server",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "seed:fault-codes": "tsx scripts/seed-fault-code-references.ts",
    "seed:demo": "tsx scripts/seed-demo-data.ts",
    "seed:demo:rollback": "tsx scripts/seed-demo-data-rollback.ts",
    "validate:demo-seed": "tsx scripts/validate-demo-seed.ts",
    "demo:seed": "tsx scripts/seed-demo-data.ts",
    "generate:pilot-codes": "tsx scripts/generate-pilot-codes.ts",
    "screenshots:local": "cross-env DEMO_CAPTURE_ENV=local tsx scripts/demo/capture-assets.ts --screenshots",
    "screenshots:staging": "cross-env DEMO_CAPTURE_ENV=staging tsx scripts/demo/capture-assets.ts --screenshots",
    "demo:video": "tsx scripts/demo/capture-assets.ts --video",
    "demo:assets": "tsx scripts/demo/capture-assets.ts --all"
  },
